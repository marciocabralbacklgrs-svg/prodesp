# ─── Segurança ────────────────────────────────────────────────────────────────
SECRET_KEY=gere-uma-chave-segura-com-python-secrets
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Plugins de acessibilidade ────────────────────────────────────────────────
ENABLE_VLIBRAS=True
ENABLE_ACESSIBILIDADE=True

# ─── Salesforce ───────────────────────────────────────────────────────────────
SF_INSTANCE_URL=https://sua-org.sandbox.my.salesforce.com
SF_CLIENT_ID=sua_consumer_key
SF_CLIENT_SECRET=seu_consumer_secret

# ─── Orquestrador ─────────────────────────────────────────────────────────────
ORQUESTRADOR_API_URL=https://api.orquestrador.example.com/api/buscador/v1/pesquisas
ORQUESTRADOR_CLIENT_ID=seu_client_id
ORQUESTRADOR_CLIENT_SECRET=seu_client_secret
